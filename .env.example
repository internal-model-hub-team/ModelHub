SECRET_KEY=replace-this-with-a-long-random-string
DATABASE_URL=postgresql+psycopg://hub:hub@postgres:5432/hub
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

GITEA_MOCK=true
GITEA_URL=http://gitea:3000
GITEA_PUBLIC_URL=http://localhost:3001
# Shared Docker Desktop address used in absolute Git LFS responses.
GITEA_ROOT_URL=http://host.docker.internal:3001/
GITEA_ADMIN_USERNAME=modelhub-admin
GITEA_ADMIN_TOKEN=

MOCK_STORAGE_ROOT=/data/mock-gitea
MAX_UPLOAD_SIZE_BYTES=5368709120
LFS_THRESHOLD_BYTES=10485760
LFS_EXTENSIONS=.safetensors,.gguf,.bin,.pt,.pth,.onnx

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
