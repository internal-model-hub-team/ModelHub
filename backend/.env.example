APP_NAME=Internal Model Hub
SECRET_KEY=replace-this-with-a-long-random-string
DATABASE_URL=sqlite:///./hub.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set false after starting Gitea with docker compose.
GITEA_MOCK=true
GITEA_URL=http://localhost:3001
GITEA_PUBLIC_URL=http://localhost:3001
GITEA_ADMIN_USERNAME=modelhub-admin
GITEA_ADMIN_TOKEN=

MOCK_STORAGE_ROOT=./mock-gitea
MAX_UPLOAD_SIZE_BYTES=5368709120
LFS_THRESHOLD_BYTES=10485760
LFS_EXTENSIONS=.safetensors,.gguf,.bin,.pt,.pth,.onnx
GIT_EXECUTABLE=git
